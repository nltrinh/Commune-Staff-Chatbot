# .env — Copy file này thành .env và chỉnh lại nếu cần

# MongoDB
MONGO_URI=mongodb://admin:admin123@localhost:27017/admin?authSource=admin&directConnection=true
MONGO_DB_NAME=ganh_da_dia_bot
COLLECTION_DOCUMENTS=documents
COLLECTION_CHAT_HISTORY=chat_history

# Ollama (chạy local tại port 11434)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# RAG
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
EMBEDDING_DIM=768

# API
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
